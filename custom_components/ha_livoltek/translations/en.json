{
  "title": "Livoltek system",
  "config": {
    "step": {
      "user": {
        "title": "Step 1/5: Livoltek API Credentials",
        "description": "Enter your Livoltek API credentials.\n\n**How to get credentials:**\n1. Go to livoltek-portal.com and log in\n2. Open My Profile (top right corner)\n3. Click Generate Token to create your User Token\n4. Click Secure ID to get your Security ID (secuid) and API Key",
        "data": {
          "server_type": "Server",
          "secuid": "Security ID (secuid)",
          "key": "API Key",
          "token": "User Token (from Livoltek portal)"
        }
      },
      "site": {
        "title": "Step 2/5: Select Site",
        "description": "Select the site (power station) you want to monitor.",
        "data": {
          "site_id": "Site"
        }
      },
      "device": {
        "title": "Step 3/5: Select Device",
        "description": "Select a device and set the update interval.",
        "data": {
          "device_sn": "Device",
          "update_interval": "Update interval (minutes)"
        }
      },
      "groups": {
        "title": "Step 4/5: Data Sources",
        "description": "Select which data groups to fetch. At least one must be selected.",
        "data": {
          "enabled_groups": "Enabled data groups"
        }
      },
      "control": {
        "title": "Step 5/5: BESS Control (optional)",
        "description": "Enter account and password for inverter control. Leave blank for monitoring only.",
        "data": {
          "account": "Account",
          "password": "Password"
        }
      }
    },
    "error": {
      "invalid_auth": "Invalid credentials. Please check secuid and key.",
      "cannot_connect": "Failed to connect to Livoltek API.",
      "no_sites": "No sites found for this account.",
      "no_devices": "No devices found for this site.",
      "invalid_site": "Invalid site selection.",
      "invalid_device": "Invalid device selection.",
      "already_configured": "This device is already configured.",
      "unknown": "An unknown error occurred.",
      "bad_request": "Bad request (400). Please check your device selection and credentials.",
      "no_groups_selected": "At least one data group must be selected."
    }
  },
